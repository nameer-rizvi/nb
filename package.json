{
  "name": "nb",
  "version": "0.1.0",
  "description": "Node.js boilerplate – An opinionated, batteries-included project structure for building Express servers and background workers.",
  "main": "src/server/index.js",
  "author": "Nameer Rizvi (https://github.com/nameer-rizvi)",
  "license": "MIT",
  "private": true,
  "keywords": [
    "boilerplate",
    "nodejs",
    "server",
    "worker"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nameer-rizvi/nb.git"
  },
  "homepage": "https://github.com/nameer-rizvi/nb#readme",
  "bugs": {
    "url": "https://github.com/nameer-rizvi/nb/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "update": "yarn && node package.update.js",
    "lint": "eslint .",
    "test": "echo \"Error: no test specified\"; exit 0",
    "test-db": "node src/database/client.test.js",
    "redis": "redis-server",
    "script": "node src/script/index.js",
    "tw": "npx @tailwindcss/cli -i src/server/router.static/css/index.css -o src/server/router.static/css/tw.css --minify",
    "tw-dev": "yarn tw --watch",
    "server": "node src/server/index.js",
    "server-dev": "NODE_ENV=development nodemon src/server/index.js",
    "dev": "concurrently --names tw,server \"yarn tw-dev\" \"yarn server-dev\"",
    "worker": "node src/worker/index.js",
    "worker-dev": "NODE_ENV=development nodemon src/worker/index.js",
    "pm2-start": "yarn && yarn tw && pm2 start ecosystem.config.js && pm2 logs",
    "pm2-restart": "yarn && yarn tw && pm2 restart ecosystem.config.js --update-env && pm2 logs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.2.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.2.4"
  },
  "dependencies": {
    "@nameer/utils": "^0.1.2",
    "@nameer/validate": "^0.1.0",
    "bowser": "^2.14.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "culori": "^4.0.2",
    "dotenv": "^17.4.2",
    "dottpath": "^0.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.9",
    "nodemailer": "^8.0.7",
    "redis": "^5.12.1",
    "sanitized": "^1.3.1",
    "undici": "^8.1.0"
  }
}
