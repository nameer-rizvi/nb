{
  "name": "nb",
  "version": "0.0.0",
  "description": "Node.js boilerplate.",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .js,.jsx; exit 0",
    "job": "node src/job/index.manual.js",
    "server": "NODE_ENV=development node src/server/index.js",
    "server-watch": "NODE_ENV=development nodemon --ignore 'src/job/*' src/server/index.js",
    "start": "NODE_ENV=production node src/server/index.js",
    "pm2-start": "npm i && pm2 start ecosystem.config.js && pm2 logs",
    "pm2-restart": "npm i && pm2 restart ecosystem.config.js --update-env && pm2 logs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nameer-rizvi/nb.git"
  },
  "keywords": [
    "express",
    "node",
    "js",
    "server",
    "microservice",
    "boilerplate"
  ],
  "author": "Nameer Rizvi (https://github.com/nameer-rizvi)",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nameer-rizvi/nb/issues"
  },
  "homepage": "https://github.com/nameer-rizvi/nb#readme",
  "devDependencies": {
    "eslint": "^8.30.0"
  },
  "dependencies": {
    "apicache": "^1.6.3",
    "bowser": "^2.11.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cron": "^2.1.0",
    "dotenv": "^16.0.3",
    "dottpath": "^0.0.5",
    "express": "^4.18.2",
    "helmet": "^6.0.1",
    "jsontxt": "^0.0.7",
    "jsonwebtoken": "^9.0.0",
    "nodemon": "^2.0.20",
    "sanitized": "^1.1.7",
    "simpul": "^0.9.2",
    "simpul-validate": "^0.1.3"
  }
}
